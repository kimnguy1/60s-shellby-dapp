{
  "name": "crypto-airdrop-studio-apps",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:api:stable": "bash ./scripts/dev-api-supervisor.sh",
    "dev:web": "bun run --cwd apps/web dev",
    "typecheck": "bun run --cwd apps/api typecheck && bun run --cwd apps/web typecheck",
    "e2e:local": "bash ./scripts/e2e-local.sh"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  }
}
